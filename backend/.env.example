# ============================================================================
# .env.example — Copy to .env and fill in real credentials.
# Never commit a populated .env file.
# ============================================================================

# --- HTTP server ---
APP_ENV=development
APP_PORT=8080
APP_READ_TIMEOUT=15s
APP_WRITE_TIMEOUT=15s
APP_SHUTDOWN_TIMEOUT=20s
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sunstore
POSTGRES_SSLMODE=disable
POSTGRES_MAX_OPEN_CONNS=25
POSTGRES_MAX_IDLE_CONNS=5
POSTGRES_CONN_MAX_LIFETIME=30m

# --- T-Bank Internet Acquiring ---
TBANK_TERMINAL_KEY=DemoTerminal
TBANK_PASSWORD=YourTerminalPassword
TBANK_API_BASE_URL=https://securepay.tinkoff.ru/v2
TBANK_INIT_TIMEOUT=15s
TBANK_NOTIFICATION_URL=http://localhost:8080/api/v1/webhooks/tbank
TBANK_RETURN_URL=http://localhost:3000/checkout/status
TBANK_FAILURE_URL=http://localhost:3000/checkout/status?status=rejected

# --- JWT (admin panel) ---
JWT_SECRET=change-me-to-a-32+char-random-string
JWT_TTL=12h
JWT_ISSUER=sunstore-api
